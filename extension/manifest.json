{
  "manifest_version": 3,
  "name": "Pinyin NLP Extension",
  "version": "0.1.0",
  "description": "Chrome Extension using Rust/Wasm for Pinyin conversion.",
  "permissions": [
    "offscreen",
    "scripting",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
