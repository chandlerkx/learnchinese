{
  "manifest_version": 3,
  "name": "learnchinese",
  "version": "0.1.0",
  "description": "Chrome Extension using Rust/Wasm for Pinyin conversion.",
  "permissions": [
    "offscreen",
    "scripting",
    "activeTab",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Learn Chinese"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}